# Shared example configuration for the frontend and backend.
# Copy this file to .env for local development, then adjust values as needed.
# Frontend variables must start with NEXT_PUBLIC_ because they are bundled into the browser.
# Backend variables use the GOODGUA_ prefix and are read by backend/app/core/config.py.

# Frontend: browser-visible API endpoint used by frontend/src/api.ts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Frontend: enables local test payment shortcuts in development screens.
NEXT_PUBLIC_ENABLE_TEST_PAYMENT=false

# Backend: development, test, or production.
GOODGUA_ENV=development

# Backend: async SQLAlchemy URL.
# SQLite relative paths are resolved from the backend process working directory.
GOODGUA_DATABASE_URL=sqlite+aiosqlite:///./goodgua-dev.db

# Backend: JWT signing secret.
# Use a strong unique value in production, at least 32 bytes.
GOODGUA_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes

# Backend: create database tables automatically on startup.
GOODGUA_AUTO_CREATE_TABLES=true

# Backend: comma-separated origins allowed to call the API with credentials.
GOODGUA_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Backend: normal user session TTL in seconds.
GOODGUA_USER_SESSION_SECONDS=86400

# Backend: admin session TTL in seconds.
GOODGUA_ADMIN_SESSION_SECONDS=7200

# Backend: enables local-only simulated payment confirmation. Production always disables it.
GOODGUA_ENABLE_PAYMENT_SIMULATOR=false

# Backend: comma-separated proxy IPs allowed to supply X-Forwarded-For.
GOODGUA_TRUSTED_PROXY_IPS=

# Backend: optional development-only admin bootstrap account.
# GOODGUA_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# GOODGUA_BOOTSTRAP_ADMIN_PASSWORD=change-me-in-local-env

# Backend: AI provider configuration for chat and analysis features.
# GOODGUA_AI_PROVIDER_BASE_URL=https://platform.aimom.net/v1
# GOODGUA_AI_PROVIDER_API_KEY=your-api-key-here
